{
  "private": true,
  "name": "studentide-browser-app",
  "description": "StudentIDE browser product",
  "productName": "StudentIDE",
  "version": "1.70.200",
  "license": "MIT",
  "author": "StudentIDE authors",
  "homepage": "https://studentide.com",
  "bugs": {
    "url": "https://studentide.com/support"
  },
  "repository": {
    "type": "git",
    "url": "https://studentide.com"
  },
  "engines": {
    "yarn": ">=1.7.0 <2",
    "node": ">=22"
  },
  "theia": {
    "frontend": {
      "config": {
        "applicationName": "StudentIDE",
        "warnOnPotentiallyInsecureHostPattern": false,
        "preferences": {
          "toolbar.showToolbar": true,
          "workbench.colorTheme": "StudentIDE Dark",
          "workbench.iconTheme": "material-icon-theme",
          "files.enableTrash": false,
          "security.workspace.trust.enabled": false
        },
        "reloadOnReconnect": true
      }
    },
    "backend": {
      "config": {
        "warnOnPotentiallyInsecureHostPattern": false,
        "startupTimeout": -1,
        "resolveSystemPlugins": false,
        "configurationFolder": ".studentide",
        "frontendConnectionTimeout": 3000
      }
    },
    "generator": {
      "config": {
        "preloadTemplate": "./resources/preload.html"
      }
    }
  },
  "dependencies": {
    "@theia/bulk-edit": "1.70.2",
    "@theia/callhierarchy": "1.70.2",
    "@theia/collaboration": "1.70.2",
    "@theia/console": "1.70.2",
    "@theia/core": "1.70.2",
    "@theia/debug": "1.70.2",
    "@theia/dev-container": "1.70.2",
    "@theia/editor": "1.70.2",
    "@theia/editor-preview": "1.70.2",
    "@theia/external-terminal": "1.70.2",
    "@theia/file-search": "1.70.2",
    "@theia/filesystem": "1.70.2",
    "@theia/getting-started": "1.70.2",
    "@theia/keymaps": "1.70.2",
    "@theia/markers": "1.70.2",
    "@theia/messages": "1.70.2",
    "@theia/metrics": "1.70.2",
    "@theia/mini-browser": "1.70.2",
    "@theia/monaco": "1.70.2",
    "@theia/navigator": "1.70.2",
    "@theia/notebook": "1.70.2",
    "@theia/output": "1.70.2",
    "@theia/plugin-dev": "1.70.2",
    "@theia/plugin-ext": "1.70.2",
    "@theia/plugin-ext-vscode": "1.70.2",
    "@theia/preferences": "1.70.2",
    "@theia/preview": "1.70.2",
    "@theia/process": "1.70.2",
    "@theia/property-view": "1.70.2",
    "@theia/remote": "1.70.2",
    "@theia/scanoss": "1.70.2",
    "@theia/scm": "1.70.2",
    "@theia/search-in-workspace": "1.70.2",
    "@theia/secondary-window": "1.70.2",
    "@theia/task": "1.70.2",
    "@theia/terminal": "1.70.2",
    "@theia/terminal-manager": "1.70.2",
    "@theia/test": "1.70.2",
    "@theia/timeline": "1.70.2",
    "@theia/toolbar": "1.70.2",
    "@theia/typehierarchy": "1.70.2",
    "@theia/userstorage": "1.70.2",
    "@theia/variable-resolver": "1.70.2",
    "@theia/vsx-registry": "1.70.2",
    "@theia/workspace": "1.70.2",
    "fs-extra": "^9.0.1",
    "studentide-product-ext": "1.70.200"
  },
  "devDependencies": {
    "@theia/cli": "1.70.2",
    "@theia/native-webpack-plugin": "1.70.2"
  },
  "scripts": {
    "clean": "theia clean && rimraf node_modules",
    "build": "yarn -s rebuild && theia build --app-target=\"browser\" --mode development",
    "build:prod": "yarn -s rebuild && theia  build --app-target=\"browser\"",
    "rebuild": "theia rebuild:browser --cacheRoot ../..",
    "start": "theia start --plugins=local-dir:../../plugins",
    "watch": "concurrently --kill-others -n tsc,build -c red,yellow \"tsc -b -w --preserveWatchOutput\" \"yarn -s watch:bundle\"",
    "update:theia": "ts-node ../../scripts/update-theia-version.ts",
    "update:next": "ts-node ../../scripts/update-theia-version.ts next"
  }
}
