    "@theia/monaco": "1.70.2",
    "@theia/vsx-registry": "1.70.2",
    "@theia/workspace": "1.70.2",
    "dompurify": "^3.2.4",
    "inversify": "^6.0.1",
    "markdown-it": "^14.1.0"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.0",
