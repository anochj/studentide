  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#9399A2", "fontStyle": "italic" }
    },
    {
      "scope": ["string", "constant.other.symbol"],
      "settings": { "foreground": "#3DC6B1" }
    },
    {
      "scope": ["constant.numeric", "constant.language", "support.constant"],
      "settings": { "foreground": "#F7C56B" }
    },
    {
      "scope": ["keyword", "storage", "storage.type"],
      "settings": { "foreground": "#8193F2" }
    },
    {
      "scope": ["entity.name.function", "support.function", "variable.function"],
      "settings": { "foreground": "#75DDCF" }
    },
    {
      "scope": ["entity.name.type", "entity.name.class", "support.type"],
      "settings": { "foreground": "#B29BFF" }
    },
    {
      "scope": ["variable", "meta.definition.variable.name"],
      "settings": { "foreground": "#CACED4" }
    },
    {
      "scope": ["variable.parameter"],
      "settings": { "foreground": "#D8BFA3" }
    },
    {
      "scope": ["invalid", "invalid.illegal"],
      "settings": { "foreground": "#FFFFFF", "background": "#F94144" }
    },
    {
      "scope": ["markup.heading"],
      "settings": { "foreground": "#3DC6B1", "fontStyle": "bold" }
    },
    {
      "scope": ["markup.italic"],
      "settings": { "fontStyle": "italic" }
    },
    {
      "scope": ["markup.bold"],
      "settings": { "fontStyle": "bold" }
    }
  ]
}
