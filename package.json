{
  "name": "studentide",
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "turbo": "^2.9.6",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.5",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "biome format \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "infra:up": "docker-compose -f docker-compose.dev.yml up --build",
    "infra:down": "docker-compose -f docker-compose.dev.yml down",
    "infra:clean": "docker-compose -f docker-compose.dev.yml down -v"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
