{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "tasks": {
    "deploy": {
      "dependsOn": ["^deploy"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": []
    },
    "infra#deploy": {
      "passThroughEnv": ["AWS_*"],
      "env": [
        "CDK_DEFAULT_ACCOUNT",
        "CDK_DEFAULT_REGION",
        "CLOUDFLARE_ZONE_ID",
        "CLOUDFLARE_API_TOKEN",
        "AwsIdeStatusWebhookSecret",
        "IDE_STATUS_WEBHOOK_URL"
      ],
      "outputs": ["cdk-outputs.json"],
      "cache": false
    },
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**"],
      "env": [
        "SKIP_ENV_VALIDATION",
        "DATABASE_URL",
        "BETTER_AUTH_URL",
        "BETTER_AUTH_SECRET",
        "GITHUB_CLIENT_ID",
        "GITHUB_CLIENT_SECRET",
        "EcsClusterName",
        "EcsSubnets",
        "EcsSecurityGroup",
        "S3ArchiverTaskDefinitionArn"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "env": ["SKIP_ENV_VALIDATION"]
    },
    "db:migrate": {
      "dependsOn": ["^db:migrate"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "env": ["DATABASE_URL"],
      "outputs": []
    }
  }
}
