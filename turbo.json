{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "tasks": {
    "deploy": {
      "dependsOn": ["^deploy"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["cdk-outputs.json"]
    },
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
