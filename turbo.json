{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "tasks": {
    "deploy": {
      "dependsOn": ["^deploy"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["cdk-outputs.json"],
      "env": [
        "CLOUDFLARE_ZONE_ID",
        "CLOUDFLARE_API_TOKEN",
        "AWS_IDE_STATUS_WEBHOOK_SECRET",
        "IDE_STATUS_WEBHOOK_URL",
        "AWS_REGION",
        "CDK_DEFAULT_REGION",
        "CDK_DEFAULT_ACCOUNT"
      ]
    },
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
