{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "tasks": {
    "deploy": {
      "dependsOn": ["^deploy"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["cdk-outputs.json"],
      "passThroughEnv": ["AWS_*"],
      "env": [
        "CDK_DEFAULT_ACCOUNT",
        "CDK_DEFAULT_REGION",
        "CLOUDFLARE_ZONE_ID",
        "CLOUDFLARE_API_TOKEN",
        "AwsIdeStatusWebhookSecret",
        "IDE_STATUS_WEBHOOK_URL"
      ]
    },
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "db:migrate": {
      "dependsOn": ["^db:migrate"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "env": ["DATABASE_URL"],
      "outputs": []
    }
  }
}
